# Supabase connection for the STAGING environment (its own Supabase project).
# Copy this file to sync/.env.staging and fill in the values. sync/.env.staging
# is gitignored — never commit real credentials.
#
# Staging is the default target for sync/push_to_supabase.py, so this is where
# runs land first. Both values are in the Supabase dashboard under
# Project Settings > API. The service_role key bypasses Row Level Security, so
# treat it as a secret.

SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
