# Supabase connection for the STAGING project (landing zone + triage + entity
# resolution — the only database sync/push_to_supabase.py writes).
# Copy this file to sync/.env.staging and fill in the values. sync/.env.staging
# is gitignored — never commit real credentials.
#
# Both values are in the Supabase dashboard under Project Settings > API.
# The service_role key bypasses Row Level Security, so treat it as a secret.

SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
