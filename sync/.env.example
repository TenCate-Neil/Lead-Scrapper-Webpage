# Supabase connection for sync/push_to_supabase.py.
# Copy this file to sync/.env and fill in the values. sync/.env is gitignored —
# never commit real credentials.
#
# Both values are in the Supabase dashboard under Project Settings > API.
# The service_role key bypasses Row Level Security, so treat it as a secret.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
