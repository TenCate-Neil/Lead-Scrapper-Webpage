# Supabase connection for the PRODUCTION project (system of record).
# Copy this file to sync/.env.production and fill in the values. sync/.env.production
# is gitignored — never commit real credentials.
#
# Production is written ONLY by the promotion job (not yet built), which moves
# accepted+resolved leads out of staging — sync/push_to_supabase.py never
# touches it. These credentials are for that job. Both values are in the
# Supabase dashboard under Project Settings > API. The service_role key
# bypasses Row Level Security, so treat it as a secret.

SUPABASE_URL=https://YOUR-PRODUCTION-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
