# Supabase connection for the PRODUCTION environment (its own Supabase project).
# Copy this file to sync/.env.production and fill in the values. sync/.env.production
# is gitignored — never commit real credentials.
#
# Production is the data the Retool BDM UI reads. The sync refuses to write here
# unless you pass BOTH --env production and --confirm-production, so a push is
# always a deliberate act. Both values are in the Supabase dashboard under
# Project Settings > API. The service_role key bypasses Row Level Security, so
# treat it as a secret.

SUPABASE_URL=https://YOUR-PRODUCTION-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key
