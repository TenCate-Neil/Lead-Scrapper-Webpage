# Generated run artifacts are large and append-only. Keep them out of git history;
# archive them in object storage. One example run is tracked (see output/README.md)
# to document the layout — everything else is ignored.
# Use a non-recursive ignore of output/ so a specific example run directory can be
# re-included: git cannot un-ignore a file whose parent directory is excluded, which
# a recursive /output/** would do. /output/* only matches depth-1 entries, so a
# re-included subdirectory's contents stay tracked.
/output/*
!/output/README.md
!/output/us-tx-austin-msa

# Local, machine-specific Claude Code settings
.claude/settings.local.json

# Location processing state can grow large / churn; track the JSON at small scale,
# ignore the SQLite form used at rollout scale.
/locations/state.db
/locations/state.db-*

# Python
__pycache__/
*.pyc
.venv/
venv/

# Supabase sync credentials — never commit. Only .env.example is tracked.
/sync/.env
.env

# OS / editor
.DS_Store
*.swp
